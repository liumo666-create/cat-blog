---
// NavBar.astro ? Premium pixel nav with dropdowns and theme toggle
---

<header>
  <div class="logo-area">
    <div class="cat-wrap" id="catWrap">
      <img id="catLogo" src="/cat1.png" alt="cat" />
    </div>
    <div class="logo-text">
      <h1>FYH BLOG</h1>
      <p>== PIXEL HAVEN ==</p>
    </div>
  </div>

  <nav class="nav-links" id="mainNav">
    <!-- 1. Home -->
    <a data-page="home" class="nav-item active">
      <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
        <polyline points="9 22 9 12 15 12 15 22"/>
      </svg>
      <span>HOME</span>
    </a>

    <!-- 2. Links (dropdown) -->
    <div class="nav-dropdown">
      <button class="nav-item nav-dropdown-trigger" data-page="links">
        <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/>
          <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/>
        </svg>
        <span>LINKS</span>
        <svg class="nav-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m6 9 6 6 6-6"/></svg>
      </button>
      <div class="dropdown-menu">
        <a href="https://www.douyin.com/user/your-id" target="_blank" class="dropdown-item">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 12a4 4 0 1 0 4 4V4a5 5 0 0 0 5 5"/></svg>
          <span>??</span>
        </a>
        <a href="https://space.bilibili.com/your-id" target="_blank" class="dropdown-item">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="12" x="3" y="8" rx="2"/><line x1="8" x2="10" y1="4" y2="6"/><line x1="16" x2="14" y1="4" y2="6"/><line x1="9" x2="9.01" y1="13" y2="13"/><line x1="15" x2="15.01" y1="13" y2="13"/></svg>
          <span>????</span>
        </a>
        <a href="https://github.com/fyh" target="_blank" class="dropdown-item">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
          <span>GitHub</span>
        </a>
      </div>
    </div>

    <!-- 3. My (dropdown) -->
    <div class="nav-dropdown">
      <button class="nav-item nav-dropdown-trigger" data-page="my">
        <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/>
          <circle cx="12" cy="7" r="4"/>
        </svg>
        <span>MY</span>
        <svg class="nav-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m6 9 6 6 6-6"/></svg>
      </button>
      <div class="dropdown-menu">
        <a href="/diary" class="dropdown-item">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1 0-5H20"/></svg>
          <span>??</span>
        </a>
        <a href="/album" class="dropdown-item">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="3" rx="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/></svg>
          <span>??</span>
        </a>
        <a href="/devices" class="dropdown-item">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="16" height="20" x="4" y="2" rx="2"/><line x1="12" x2="12.01" y1="18" y2="18"/></svg>
          <span>????</span>
        </a>
      </div>
    </div>

    <!-- 4. About -->
    <a href="/about" class="nav-item">
      <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="10"/>
        <path d="M12 16v-4"/>
        <path d="M12 8h.01"/>
      </svg>
      <span>ABOUT</span>
    </a>

    <!-- 5. Projects -->
    <a data-page="projects" class="nav-item">
      <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="m8 3 4 8 5-5 5 15H2L8 3z"/>
      </svg>
      <span>PROJECTS</span>
    </a>
  </nav>

  <button class="theme-toggle-btn" aria-label="Toggle day/night mode" title="Switch theme">
    <svg class="icon-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
    </svg>
    <svg class="icon-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <circle cx="12" cy="12" r="5"/>
      <line x1="12" y1="1" x2="12" y2="3"/>
      <line x1="12" y1="21" x2="12" y2="23"/>
      <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
      <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
      <line x1="1" y1="12" x2="3" y2="12"/>
      <line x1="21" y1="12" x2="23" y2="12"/>
      <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
      <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
    </svg>
  </button>
</header>

<style>
  header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-bottom: 16px;
    margin-bottom: 18px;
    border-bottom: 4px solid var(--pink);
    flex-wrap: wrap;
    gap: 14px;
  }

  /* ===== Logo ===== */
  .logo-area {
    display: flex;
    align-items: center;
    gap: 14px;
  }
  .cat-wrap {
    width: 64px;
    height: 64px;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    position: relative;
  }
  .cat-wrap img {
    width: 64px;
    height: 64px;
    object-fit: contain;
    image-rendering: pixelated;
    filter: drop-shadow(2px 2px 0 rgba(0, 0, 0, 0.9));
    transition: transform 0.12s;
  }
  .cat-wrap:hover img {
    transform: scale(1.08);
  }
  .logo-text h1 {
    font-family: var(--fp);
    font-size: 20px;
    font-weight: 700;
    color: #fff;
    text-shadow: 3px 3px 0 #000;
    margin-bottom: 4px;
    letter-spacing: 1px;
    line-height: 1.25;
  }
  .logo-text p {
    font-family: var(--fm);
    font-size: 11px;
    color: var(--pink);
    letter-spacing: 3px;
  }

  /* ===== Nav Links ===== */
  .nav-links {
    display: flex;
    align-items: center;
    gap: 4px;
    flex-wrap: wrap;
  }

  /* ===== Nav Item ===== */
  .nav-item {
    display: flex;
    align-items: center;
    gap: 6px;
    font-family: var(--fm);
    font-size: 12px;
    font-weight: 600;
    color: var(--text);
    padding: 8px 14px;
    border: 2px solid transparent;
    border-radius: 12px;
    background: transparent;
    cursor: pointer;
    transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
    position: relative;
    text-decoration: none;
    white-space: nowrap;
  }
  .nav-item:hover {
    color: var(--pink);
    border-color: var(--b-hi);
    background: var(--hover);
    transform: translateY(-1px);
  }
  .nav-item.active {
    color: var(--pink);
    border-color: var(--pink);
    background: rgba(255, 102, 204, 0.1);
    box-shadow: 0 0 16px rgba(255, 102, 204, 0.15);
  }
  .nav-icon {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .nav-item:hover .nav-icon {
    transform: scale(1.15);
  }
  .nav-chevron {
    width: 14px;
    height: 14px;
    flex-shrink: 0;
    opacity: 0.5;
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  /* ===== Dropdown ===== */
  .nav-dropdown {
    position: relative;
  }
  .dropdown-menu {
    position: absolute;
    top: calc(100% + 8px);
    left: 50%;
    transform: translateX(-50%) translateY(6px);
    min-width: 160px;
    padding: 6px;
    background: var(--glass);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border: 2px solid var(--b-hi);
    border-radius: 14px;
    box-shadow: 0 16px 48px rgba(0, 0, 0, 0.5), 0 0 0 1px rgba(255, 102, 204, 0.1);
    opacity: 0;
    visibility: hidden;
    transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
    z-index: 100;
    pointer-events: none;
  }
  .nav-dropdown:hover .dropdown-menu {
    opacity: 1;
    visibility: visible;
    transform: translateX(-50%) translateY(0);
    pointer-events: auto;
  }
  .nav-dropdown:hover .nav-chevron {
    transform: rotate(180deg);
    opacity: 1;
  }
  .nav-dropdown:hover .nav-dropdown-trigger {
    color: var(--pink);
    border-color: var(--b-hi);
    background: var(--hover);
  }

  .dropdown-item {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 14px;
    border-radius: 10px;
    font-family: var(--fb);
    font-size: 13px;
    color: var(--text);
    text-decoration: none;
    transition: all 0.2s ease;
    cursor: pointer;
  }
  .dropdown-item svg {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
    opacity: 0.7;
  }
  .dropdown-item:hover {
    background: var(--hover);
    color: var(--cyan);
  }
  .dropdown-item:hover svg {
    opacity: 1;
    color: var(--cyan);
  }
  .dropdown-item:first-child:hover {
    color: var(--pink);
  }
  .dropdown-item:first-child:hover svg {
    color: var(--pink);
  }

  /* ===== Theme Toggle ===== */
  .theme-toggle-btn {
    width: 38px;
    height: 38px;
    border-radius: 50%;
    border: 2px solid var(--b-hi);
    background: var(--card);
    color: var(--yellow);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.35s cubic-bezier(0.4, 0, 0.2, 1);
    flex-shrink: 0;
    position: relative;
    overflow: hidden;
    margin-left: 8px;
  }
  .theme-toggle-btn:hover {
    border-color: var(--yellow);
    background: rgba(255, 221, 68, 0.1);
    box-shadow: 0 0 20px rgba(255, 221, 68, 0.3);
    transform: scale(1.1);
  }
  .theme-toggle-btn:active {
    transform: scale(0.92);
    transition: transform 0.1s;
  }
  .theme-toggle-btn svg {
    width: 19px;
    height: 19px;
    transition: transform 0.5s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.35s;
    pointer-events: none;
  }
  .theme-toggle-btn .icon-moon {
    position: absolute;
  }
  .theme-toggle-btn .icon-sun {
    position: absolute;
    opacity: 0;
    transform: rotate(90deg) scale(0.5);
  }
  .theme-toggle-btn.day .icon-moon {
    opacity: 0;
    transform: rotate(-90deg) scale(0.5);
  }
  .theme-toggle-btn.day .icon-sun {
    opacity: 1;
    transform: rotate(0deg) scale(1);
  }
  .theme-toggle-btn::before {
    content: "";
    position: absolute;
    inset: -2px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(255, 221, 68, 0.3) 0%, transparent 70%);
    opacity: 0;
    transition: opacity 0.35s;
  }
  .theme-toggle-btn:hover::before {
    opacity: 1;
  }
</style>

<script>
  // @ts-nocheck
  // Cat logo randomizer
  const catWrap = document.getElementById("catWrap");
  const catLogo = /** @type {HTMLImageElement} */ (/** @type {unknown} */ (document.getElementById("catLogo")));
  if (catWrap && catLogo) {
    catWrap.addEventListener("click", () => {
      const n = Math.floor(Math.random() * 9) + 1;
      catLogo.src = `/cat${n}.png`;
    });
  }
</script>
