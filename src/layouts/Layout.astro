---
import '../styles/global.css';
import SakuraEffect from "@components/SakuraEffect.astro";

interface Props { title?: string; description?: string; }

const { title, description } = Astro.props;
// 👇 核心修改 1：将标题模板和默认乱码改为 "FYH的工作站"
const pageTitle = title ? `${title} - FYH的工作站` : "FYH的工作站";
const pageDesc = description || "CODE. DESIGN. LIFE. \u2014\u2014 \u50cf\u7d20\u827a\u672f\u4e0e\u4ee3\u7801\u7684\u4e2a\u4eba\u7a7a\u95f4";
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDesc} />
    
    <!-- 👇 核心修改 2：彻底移除 SVG 文字猫图标，引入 public 目录下的 cat.png -->
    <link rel="icon" type="image/png" href="/cat.png" />
    
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Pixelify+Sans:wght@400..700&family=Noto+Sans+SC:wght@300;400;500;700&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet" />
    
    <!-- 🌟 终极防闪烁：在浏览器绘制第一帧前，拦截并注入日间模式 🌟 -->
    <script is:inline>
      (function() {
        // 1. 封杀所有动画，防止加载时的残留特效
        var style = document.createElement('style');
        style.id = 'theme-preload-blocker';
        style.textContent = '*, *::before, *::after { transition: none !important; animation: none !important; }';
        document.head.appendChild(style);

        // 2. 提前读取本地存储
        try {
          var theme = localStorage.getItem('fyh-theme');
          if (theme === 'day') {
            // 3. 使用 MutationObserver 蹲点，DOM 生成的一瞬间注入 class
            var observer = new MutationObserver(function(mutations, obs) {
              var scene = document.querySelector('.game-scene');
              var btn = document.querySelector('.theme-toggle-btn');
              
              if (scene && !scene.classList.contains('day-mode')) {
                scene.classList.add('day-mode');
              }
              if (btn && !btn.classList.contains('day')) {
                btn.classList.add('day');
              }
              
              if (scene && btn) {
                obs.disconnect(); // 拦截完成，事了拂衣去
              }
            });
            observer.observe(document.documentElement, { childList: true, subtree: true });
          }
        } catch(e) {}
      })();
    </script>
  </head>
  <body>
    <SakuraEffect />
    <slot />
    <script>
// @ts-nocheck
      (function() {
        var SCENE = '.game-scene';
        var BTN = '.theme-toggle-btn';
        var KEY = 'fyh-theme';
        function gs(sel) { return document.querySelector(sel); }
        
        function updateRipple() {
          var btn = gs(BTN), scene = gs(SCENE);
          if (!btn || !scene) return;
          var br = btn.getBoundingClientRect(), sr = scene.getBoundingClientRect();
          var cx = ((br.left + br.width / 2) - sr.left) / sr.width * 100;
          var cy = ((br.top + br.height / 2) - sr.top) / sr.height * 100;
          scene.style.setProperty('--ripple-x', cx + '%');
          scene.style.setProperty('--ripple-y', cy + '%');
        }
        
        function setTheme(t, isClick) {
          var scene = gs(SCENE), btn = gs(BTN);
          if (!scene || !btn) return;
          
          if (isClick) {
            updateRipple();
          }
          
          if (t === 'day') { scene.classList.add('day-mode'); btn.classList.add('day'); }
          else { scene.classList.remove('day-mode'); btn.classList.remove('day'); }
          try { localStorage.setItem(KEY, t); } catch(e) {}
        }
        
        function toggle() {
          var scene = gs(SCENE); if (!scene) return;
          setTheme(scene.classList.contains('day-mode') ? 'night' : 'day', true);
        }
        
        function init() {
          var t = 'night';
          try { var s = localStorage.getItem(KEY); if (s === 'day' || s === 'night') t = s; } catch(e) {}
          setTheme(t, false);
        }
        
        document.addEventListener('click', function(e) {
          var b = e.target.closest(BTN); if (b) toggle();
        });
        
        init();
        
        // 撤销封杀令，恢复完美点击扩散动画
        requestAnimationFrame(function() {
          requestAnimationFrame(function() {
            var blocker = document.getElementById('theme-preload-blocker');
            if (blocker) blocker.remove();
          });
        });
        
        window.addEventListener('resize', updateRipple);
        
        /* Mouse glow tracking for all glass cards */
        document.addEventListener('mousemove', function(e) {
          document.querySelectorAll('.post-card, .glass-card').forEach(function(c) {
            var r = c.getBoundingClientRect();
            c.style.setProperty('--mouse-x', ((e.clientX - r.left) / r.width) * 100 + '%');
            c.style.setProperty('--mouse-y', ((e.clientY - r.top) / r.height) * 100 + '%');
          });
        });
        
        /* Mouse tracking for glass-card mc-x/mc-y */
        document.addEventListener('mousemove', function(e) {
          document.querySelectorAll('.glass-card').forEach(function(c) {
            var r = c.getBoundingClientRect();
            c.style.setProperty('--mc-x', ((e.clientX - r.left) / r.width) * 100 + '%');
            c.style.setProperty('--mc-y', ((e.clientY - r.top) / r.height) * 100 + '%');
          });
        });
      })();
    </script>
  </body>
</html>