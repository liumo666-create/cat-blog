                             }
                           }
                           
                           // 优先级：真实字段 > URL参数提取 > 邮箱前缀 > 匿名用户
                           var displayName = c.name ? c.name : (hiddenName ? hiddenName : (c.email ? c.email.split('@')[0] : '匿名用户'));
                           
                           return '\x3Cdiv class="diary-comment-item"\x3E' +
                                    '\x3Cimg src="' + (c.avatar_url || '/cat1.png') + '" class="comment-avatar" onerror="this.src=\'/cat1.png\'" \x3E' +
                                    '\x3Cdiv class="comment-content-box"\x3E' +
                                      '\x3Cspan class="comment-email"\x3E' + displayName + '\x3C/span\x3E' +
                                      '\x3Cspan class="comment-text"\x3E' + c.content + '\x3C/span\x3E' +
