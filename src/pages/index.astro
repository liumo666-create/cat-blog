<script>
// @ts-nocheck
  var KEYS = { articles: 'fyh_articles', calendar: 'fyh_calendar', albums: 'fyh_albums', weatherCache: 'fyh_weather' };

  function getCalendar() { try { return JSON.parse(localStorage.getItem(KEYS.calendar) || '{}'); } catch(e) { return {}; } }
  function saveCalendar(o) { try { localStorage.setItem(KEYS.calendar, JSON.stringify(o)); } catch(e) {} }
  function getAlbums() { try { return JSON.parse(localStorage.getItem(KEYS.albums) || '[]'); } catch(e) { return []; } }
  function saveAlbums(a) { try { localStorage.setItem(KEYS.albums, JSON.stringify(a)); } catch(e) {} }

  /* ===== Markdown 丝滑分页逻辑 ===== */
  var currentPage = 1;
  var maxPage = parseInt(document.getElementById('nextPage')?.dataset.max || 1);
  var postItems = document.querySelectorAll('.post-item');
  
  function updatePagination() {
    postItems.forEach(function(item) {
      if (item.classList.contains('page-' + currentPage)) {
        item.style.display = 'block';
        item.style.animation = 'fadeInUp 0.4s ease forwards';
      } else {
        item.style.display = 'none';
      }
    });
    
    var prevBtn = document.getElementById('prevPage');
    var nextBtn = document.getElementById('nextPage');
    var indicator = document.getElementById('pageIndicator');
    
    if(prevBtn) { prevBtn.disabled = currentPage === 1; prevBtn.style.opacity = currentPage === 1 ? '0.4' : '1'; }
    if(nextBtn) { nextBtn.disabled = currentPage === maxPage; nextBtn.style.opacity = currentPage === maxPage ? '0.4' : '1'; }
    if(indicator) indicator.textContent = currentPage + ' / ' + maxPage;
    
    var sc = document.getElementById('scrollContainer');
    if (sc) sc.scrollTo({ top: 0, behavior: 'smooth' });
  }

  document.getElementById('prevPage')?.addEventListener('click', function() {
    if (currentPage > 1) { currentPage--; updatePagination(); }
  });
  document.getElementById('nextPage')?.addEventListener('click', function() {
    if (currentPage < maxPage) { currentPage++; updatePagination(); }
  });

  /* ===== Clock ===== */
  function updateClock() {
    var now = new Date();
    var clk = document.getElementById('widgetClock');
    var dat = document.getElementById('widgetDate');
    if (clk) clk.textContent = now.toLocaleTimeString('zh-CN', { hour: '2-digit', minute: '2-digit', second: '2-digit' });
    if (dat) dat.textContent = now.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric', weekday: 'long' });
  }
  setInterval(updateClock, 1000); updateClock();

  /* ===== Weather (Dynamic Enhanced) ===== */
  function fetchWeather() {
    var cached = null;
    try { cached = JSON.parse(localStorage.getItem(KEYS.weatherCache) || 'null'); } catch(e) {}
    // 注意这里多传入了 cached.code，以确保刷新时也能触发正确的动画
    if (cached && Date.now() - cached.time < 1800000) { showWeather(cached.temp, cached.desc, cached.code); return; }
    
    // 【核心修改 1：将经纬度精准定位到 湖北荆州 (纬度 30.33, 经度 112.23)】
    fetch('https://api.open-meteo.com/v1/forecast?latitude=30.33&longitude=112.23&current_weather=true')
      .then(function(r) { return r.json(); })
      .then(function(data) {
        var temp = data.current_weather.temperature;
        var code = data.current_weather.weathercode;
        var descs = {};
        for (var i = 0; i <= 3; i++) descs[i] = '晴朗';
        for (var i = 45; i <= 48; i++) descs[i] = '雾';
        for (var i = 51; i <= 55; i++) descs[i] = '毛毛雨';
        for (var i = 56; i <= 57; i++) descs[i] = '冻雨';
        for (var i = 61; i <= 65; i++) descs[i] = '雨';
        for (var i = 66; i <= 67; i++) descs[i] = '大雨';
        for (var i = 71; i <= 75; i++) descs[i] = '雪';
        for (var i = 77; i <= 77; i++) descs[i] = '雪粒';
        for (var i = 80; i <= 82; i++) descs[i] = '阵雨';
        for (var i = 85; i <= 86; i++) descs[i] = '阵雪';
        for (var i = 95; i <= 95; i++) descs[i] = '雷暴';
        for (var i = 96; i <= 99; i++) descs[i] = '雷暴伴冰雹';
        var desc = descs[code] || '未知';
        
        showWeather(temp, desc, code);
        try { localStorage.setItem(KEYS.weatherCache, JSON.stringify({ temp: temp, desc: desc, code: code, time: Date.now() })); } catch(e) {}
      }).catch(function() { showWeather('--', '无法获取天气', -1); });
  }

  function showWeather(temp, desc, code) {
    var t = document.getElementById('weatherTemp');
    var d = document.getElementById('weatherDesc');
    var rainEffect = document.querySelector('.pixel-rain'); // 获取我们在 HTML 中预埋的纯 CSS 雨滴层
    
    if (t) t.textContent = temp + '°';
    if (d) d.textContent = desc;
    
    // 【核心修改 2：根据 Open-Meteo 的天气代码动态控制特效】
    if (rainEffect) {
      // 判断当前是否属于降水天气 (毛毛雨/雨/阵雨/雷暴等)
      var isRaining = (code >= 51 && code <= 67) || (code >= 80 && code <= 82) || (code >= 95 && code <= 99);
      
      // 如果是雨天，显示像素雨；如果是晴天或多云，则隐藏（保证逻辑严密）
      rainEffect.style.display = isRaining ? 'block' : 'none';
    }
  }
  fetchWeather();

  /* ===== Calendar ===== */
  var calYear, calMonth, calendarData = getCalendar(), calSelectedDate = null, entryType = 'note';
  function renderCalendar() {
    var now = new Date();
    if (!calYear) { calYear = now.getFullYear(); calMonth = now.getMonth(); }
    var label = document.getElementById('calMonthLabel');
    if (label) label.textContent = calYear + '年 ' + (calMonth + 1) + '月';
    var grid = document.getElementById('calGrid'); if (!grid) return;
    var headers = ['日','一','二','三','四','五','六'];
    var html = headers.map(function(h){return '<div class="day-header">'+h+'</div>';}).join('');
    var firstDay = new Date(calYear, calMonth, 1).getDay();
    var daysInMonth = new Date(calYear, calMonth + 1, 0).getDate();
    var prevDays = new Date(calYear, calMonth, 0).getDate();
    var todayStr = now.getFullYear()+'-'+String(now.getMonth()+1).padStart(2,'0')+'-'+String(now.getDate()).padStart(2,'0');
    for (var i = firstDay - 1; i >= 0; i--) {
      var d = prevDays - i;
      var m = calMonth === 0 ? 12 : calMonth;
      var y = calMonth === 0 ? calYear - 1 : calYear;
      var ds = y+'-'+String(m).padStart(2,'0')+'-'+String(d).padStart(2,'0');
      html += '<div class="day-cell other-month" data-date="'+ds+'">'+d+'</div>';
    }
    for (var d = 1; d <= daysInMonth; d++) {
      var ds = calYear+'-'+String(calMonth+1).padStart(2,'0')+'-'+String(d).padStart(2,'0');
      var classes = ['day-cell'];
      if (ds === todayStr) classes.push('today');
      if (calendarData[ds] && calendarData[ds].length > 0) classes.push('has-entry');
      html += '<div class="'+classes.join(' ')+'" data-date="'+ds+'">'+d+'</div>';
    }
    var remaining = 42 - (firstDay + daysInMonth);
    for (var d = 1; d <= remaining; d++) {
      var m = calMonth === 11 ? 1 : calMonth + 2;
      var y = calMonth === 11 ? calYear + 1 : calYear;
      var ds = y+'-'+String(m).padStart(2,'0')+'-'+String(d).padStart(2,'0');
      html += '<div class="day-cell other-month" data-date="'+ds+'">'+d+'</div>';
    }
    grid.innerHTML = html;
  }

  /* Calendar nav */
  (function(){
    document.getElementById('calPrev').addEventListener('click', function(){ calMonth--; if(calMonth<0){calMonth=11;calYear--;} renderCalendar(); });
    document.getElementById('calNext').addEventListener('click', function(){ calMonth++; if(calMonth>11){calMonth=0;calYear++;} renderCalendar(); });
    document.getElementById('calGrid').addEventListener('click', function(e){
      var cell = e.target.closest('.day-cell');
      if (cell && cell.dataset.date) { calSelectedDate = cell.dataset.date; openEntryModal(calSelectedDate); }
    });
  })();

  /* ===== Entry Modal ===== */
  function openEntryModal(dateStr) {
    document.getElementById('entryModalTitle').textContent = dateStr + ' 的记录';
    document.getElementById('entryTitle').value = '';
    document.getElementById('entryContent').value = '';
    entryType = 'note';
    document.querySelectorAll('.entry-type-btn').forEach(function(b){ b.classList.remove('active'); });
    document.querySelector('.entry-type-btn[data-type="note"]').classList.add('active');
    renderEntryList(dateStr);
    document.getElementById('entryModal').style.display = 'flex';
  }
  function renderEntryList(dateStr) {
    var list = document.getElementById('entryList'); if (!list) return;
    var entries = calendarData[dateStr] || [];
    list.innerHTML = entries.map(function(e, i){
      var tl = e.type==='article'?'[文章]':e.type==='photo'?'[照片]':'[笔记]';
      return '<div class="entry-entry"><span>'+tl+' '+e.title+'</span><span class="del-btn" data-idx="'+i+'">×</span></div>';
    }).join('');
  }
  document.getElementById('entryList').addEventListener('click', function(e){
    var del = e.target.closest('.del-btn'); if (!del) return;
    var idx = parseInt(del.dataset.idx);
    if (!calendarData[calSelectedDate]) return;
    calendarData[calSelectedDate].splice(idx, 1);
    if (calendarData[calSelectedDate].length === 0) delete calendarData[calSelectedDate];
    saveCalendar(calendarData);
    renderEntryList(calSelectedDate);
    renderCalendar();
  });
  document.querySelectorAll('.entry-type-btn').forEach(function(btn){
    btn.addEventListener('click', function(){
      document.querySelectorAll('.entry-type-btn').forEach(function(b){ b.classList.remove('active'); });
      btn.classList.add('active');
      entryType = btn.dataset.type;
    });
  });
  document.getElementById('btnEntrySave').addEventListener('click', function(){
    var title = document.getElementById('entryTitle').value.trim();
    if (!title) { alert('请输入标题'); return; }
    if (!calendarData[calSelectedDate]) calendarData[calSelectedDate] = [];
    calendarData[calSelectedDate].push({
      title: title,
      content: document.getElementById('entryContent').value.trim(),
      type: entryType,
      time: new Date().toISOString()
    });
    saveCalendar(calendarData);
    document.getElementById('entryTitle').value = '';
    document.getElementById('entryContent').value = '';
    renderEntryList(calSelectedDate);
    renderCalendar();
  });
  document.getElementById('btnEntryCancel').addEventListener('click', function(){
    document.getElementById('entryModal').style.display = 'none';
  });

  /* ===== Markdown Renderer ===== */
  function simpleMarkdown(text) {
    var html = text
      .replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;')
      .replace(/^### (.+)$/gm, '<h3>$1</h3>')
      .replace(/^## (.+)$/gm, '<h2>$1</h2>')
      .replace(/^# (.+)$/gm, '<h1>$1</h1>')
      .replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
      .replace(/\*(.+?)\*/g, '<em>$1</em>')
      .replace(/`([^`]+)`/g, '<code>$1</code>')
      .replace(/!\[([^\]]*)\]\(([^)]+)\)/g, '<img src="$2" alt="$1" style="max-width:100%;border-radius:8px;" />')
      .replace(/\[([^\]]+)\]\(([^)]+)\)/g, '<a href="$2" target="_blank" rel="noopener">$1</a>')
      .replace(/^- (.+)$/gm, '<li>$1</li>')
      .replace(/(<li>.*<\/li>)/gs, function(m){ return '<ul>'+m+'</ul>'; })
      .replace(/\n\n/g, '</p><p>')
      .replace(/\n/g, '<br />');
    return '<p>'+html+'</p>';
  }

  /* ===== Editor ===== */
  var mdEditor = document.getElementById('mdEditor');
  var mdPreview = document.getElementById('mdPreview');
  if (mdEditor && mdPreview) {
    mdEditor.addEventListener('input', function(){ mdPreview.innerHTML = simpleMarkdown(mdEditor.value); });
  }
  document.getElementById('btnPublish').addEventListener('click', function(){
    var title = document.getElementById('articleTitle').value.trim();
    var content = mdEditor.value.trim();
    if (!title || !content) { alert('请输入标题和内容'); return; }
    var articles = getArticles();
    articles.unshift({
      id: Date.now(),
      title: title,
      excerpt: content.replace(/[#*`\[\]!()]/g, '').substring(0, 120) + '...',
      date: new Date().toISOString().split('T')[0],
      category: '文章',
      tags: ['原创']
    });
    saveArticles(articles);
    renderPosts();
    document.getElementById('articleTitle').value = '';
    mdEditor.value = '';
    mdPreview.innerHTML = '';
    /* Navigate to home */
    document.querySelectorAll('.section-page').forEach(function(s){ s.classList.remove('active'); });
    document.getElementById('page-home').classList.add('active');
    document.querySelectorAll('#mainNav .nav-item').forEach(function(l){ l.classList.remove('active'); });
    var hn = document.querySelector('[data-page="home"]');
    if (hn) hn.classList.add('active');
  });

  /* ===== Albums ===== */
  function renderAlbums() {
    var grid = document.getElementById('albumGrid'); if (!grid) return;
    var albums = getAlbums();
    var totalPhotos = 0;
    var html = '';
    albums.forEach(function(album, ai) {
      totalPhotos += (album.photos || []).length;
      var cover = album.photos && album.photos.length > 0 ? album.photos[0] : '';
      var scatter = '';
      var scatterPhotos = (album.photos || []).slice(0, 4);
      for (var i = 0; i < Math.min(4, scatterPhotos.length); i++) {
        scatter += '<img class="scatter-photo" src="'+scatterPhotos[i]+'" loading="lazy" />';
      }
      html += '<div class="album-set" data-album="'+ai+'">' +
        (cover ? '<img class="cover-img" src="'+cover+'" loading="lazy" />' : '<div style="display:flex;align-items:center;justify-content:center;height:100%;color:var(--dim);font-size:14px;">空相册</div>') +
        (scatterPhotos.length > 0 ? '<div class="scatter-layer">'+scatter+'</div>' : '') +
        '<div class="album-set-overlay">'+album.name+'<span class="album-set-count">'+(album.photos||[]).length+' 张</span></div>' +
        '</div>';
    });
    html += '<div class="album-upload-card" id="albumUpload"><div class="album-upload-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg></div><span class="album-upload-text">新建相册集</span></div>';
    grid.innerHTML = html;

    /* Update stats */
    var ac = document.getElementById('albumCount'), pc = document.getElementById('photoCount');
    if (ac) ac.textContent = albums.length;
    if (pc) pc.textContent = totalPhotos;
    var sp = document.getElementById('statPhotos'); if (sp) sp.textContent = albums.length;

    /* Upload trigger */
    var uz = document.getElementById('albumUpload');
    var fi = document.getElementById('albumFileInput');
    if (uz && fi) {
      uz.addEventListener('click', function(e) { e.stopPropagation(); fi.click(); });
    }

    /* Album click > viewer */
    grid.querySelectorAll('.album-set').forEach(function(set){
      set.addEventListener('click', function(e) {
        if (e.target.closest('.album-upload-card')) return;
        openAlbumViewer(parseInt(set.dataset.album));
      });
    });
  }

  var currentViewingAlbum = -1;
  function openAlbumViewer(idx) {
    currentViewingAlbum = idx;
    var albums = getAlbums(), album = albums[idx];
    if (!album) return;
    var titleEl = document.getElementById('albumViewerTitle');
    if (titleEl) titleEl.textContent = album.name;
    var imgs = document.getElementById('albumViewerImages');
    if (imgs) {
      imgs.innerHTML = (album.photos || []).map(function(p, pi) {
        return '<div class="album-viewer-photo" data-photo-idx="'+pi+'"><img src="'+p+'" loading="lazy" /><span class="photo-del" data-del="'+pi+'">×</span></div>';
      }).join('');
      if ((album.photos || []).length === 0) {
        imgs.innerHTML = '<div style="color:var(--dim);font-size:14px;text-align:center;padding:40px;">暂无照片<br/>点击下方按钮添加</div>';
      }
    }
    var viewer = document.getElementById('albumViewer');
    if (viewer) viewer.style.display = 'flex';
  }

  /* Album viewer controls */
  var btnAlbumClose = document.getElementById('btnAlbumClose');
  if (btnAlbumClose) btnAlbumClose.addEventListener('click', function(){
    var viewer = document.getElementById('albumViewer');
    if (viewer) viewer.style.display = 'none';
    renderAlbums();
  });
  var btnAddToAlbum = document.getElementById('btnAddToAlbum');
  if (btnAddToAlbum) btnAddToAlbum.addEventListener('click', function(){
    var fi = document.getElementById('albumAddFileInput');
    if (fi) fi.click();
  });
  var albumAddFileInput = document.getElementById('albumAddFileInput');
  if (albumAddFileInput) albumAddFileInput.addEventListener('change', function(e){
    var files = e.target.files;
    if (!files.length || currentViewingAlbum < 0) return;
    var albums = getAlbums(), album = albums[currentViewingAlbum];
    if (!album) return;
    if (!album.photos) album.photos = [];
    var loaded = 0;
    for (var i = 0; i < files.length; i++) {
      (function(file){
        var r = new FileReader();
        r.onload = function(ev) {
          album.photos.push(ev.target.result);
          loaded++;
          if (loaded === files.length) {
            saveAlbums(albums);
            openAlbumViewer(currentViewingAlbum);
            renderAlbums();
          }
        };
        r.readAsDataURL(file);
      })(files[i]);
    }
    e.target.value = '';
  });
  /* Delete album */
  var btnDeleteAlbum = document.getElementById('btnDeleteAlbum');
  if (btnDeleteAlbum) btnDeleteAlbum.addEventListener('click', function(){
    if (currentViewingAlbum < 0) return;
    if (!confirm('确定要删除这个相册吗？此操作不可撤销。')) return;
    var albums = getAlbums();
    albums.splice(currentViewingAlbum, 1);
    saveAlbums(albums);
    var viewer = document.getElementById('albumViewer');
    if (viewer) viewer.style.display = 'none';
    currentViewingAlbum = -1;
    renderAlbums();
  });
  /* Delete photo from viewer */
  var albumViewerImages = document.getElementById('albumViewerImages');
  if (albumViewerImages) albumViewerImages.addEventListener('click', function(e){
    var del = e.target.closest('[data-del]'); if (!del) return;
    e.stopPropagation();
    var pi = parseInt(del.dataset.del), albums = getAlbums();
    if (currentViewingAlbum >= 0 && albums[currentViewingAlbum]) {
      albums[currentViewingAlbum].photos.splice(pi, 1);
      saveAlbums(albums);
      openAlbumViewer(currentViewingAlbum);
      renderAlbums();
    }
  });
  /* Lightbox on photo click */
  if (albumViewerImages) albumViewerImages.addEventListener('click', function(e){
    var photo = e.target.closest('.album-viewer-photo');
    if (!photo || e.target.closest('.photo-del')) return;
    var pi = parseInt(photo.dataset.photoIdx);
    showLightbox(currentViewingAlbum, pi);
  });
  /* Lightbox */
  var lightboxEl = null;
  function showLightbox(albumIdx, photoIdx) {
    var albums = getAlbums();
    if (albumIdx < 0 || !albums[albumIdx] || !albums[albumIdx].photos[photoIdx]) return;
    closeLightbox();
    lightboxEl = document.createElement('div');
    lightboxEl.className = 'lightbox-overlay';
    var navPrev = photoIdx > 0 ? '<span class="lightbox-nav prev"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18"><path d="m15 18-6-6 6-6"/></svg></span>' : '';
    var navNext = photoIdx < albums[albumIdx].photos.length - 1 ? '<span class="lightbox-nav next"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18"><path d="m9 18 6-6-6-6"/></svg></span>' : '';
    lightboxEl.innerHTML = '<span class="lightbox-close">×</span>' + navPrev + navNext + '<img src="'+albums[albumIdx].photos[photoIdx]+'" />';
    lightboxEl.addEventListener('click', function(e) {
      if (e.target.classList.contains('lightbox-close') || e.target === lightboxEl) { closeLightbox(); return; }
      if (e.target.closest('.lightbox-nav.prev') && photoIdx > 0) { showLightbox(albumIdx, photoIdx - 1); }
      if (e.target.closest('.lightbox-nav.next') && photoIdx < albums[albumIdx].photos.length - 1) { showLightbox(albumIdx, photoIdx + 1); }
    });
    document.body.appendChild(lightboxEl);
    document.addEventListener('keydown', lightboxKeyHandler);
  }
  function closeLightbox() {
    if (lightboxEl) { lightboxEl.remove(); lightboxEl = null; }
    document.removeEventListener('keydown', lightboxKeyHandler);
  }
  function lightboxKeyHandler(e) {
    if (e.key === 'Escape') closeLightbox();
  }
  /* File input for new album */
  document.getElementById('albumFileInput').addEventListener('change', function(e){
    var files = e.target.files;
    if (!files.length) return;
    var name = prompt('请输入相册集名称：', '新相册 ' + new Date().toLocaleDateString('zh-CN'));
    if (!name) { e.target.value = ''; return; }
    var albums = getAlbums();
    var newAlbum = { name: name, photos: [], created: new Date().toISOString() };
    var loaded = 0;
    for (var i = 0; i < files.length; i++) {
      (function(file){
        var r = new FileReader();
        r.onload = function(ev) {
          newAlbum.photos.push(ev.target.result);
          loaded++;
          if (loaded === files.length) {
            albums.push(newAlbum);
            saveAlbums(albums);
            renderAlbums();
          }
        };
        r.readAsDataURL(file);
      })(files[i]);
    }
    if (files.length === 0) { albums.push(newAlbum); saveAlbums(albums); renderAlbums(); }
    e.target.value = '';
  });

  /* ===== Modal backdrop click to close ===== */
  document.getElementById('entryModal').addEventListener('click', function(e){
    if (e.target === this) this.style.display = 'none';
  });
  document.getElementById('albumViewer').addEventListener('click', function(e){
    if (e.target === this) { this.style.display = 'none'; renderAlbums(); }
  });

  /* ===== Render Projects ===== */
  var PROJECTS = [
    { id: 0, name: "FYH Blog", desc: "像素风格个人博客，Astro + Svelte 构建，支持 Markdown 写作、相册管理、日历记事、日夜主题切换。", icon: "猫", status: "活跃开发中", accent: "var(--pink)", iconBg: "rgba(255,107,157,0.1)", statusBg: "rgba(255,107,157,0.1)", tags: ["Astro","Svelte","CSS"] },
    { id: 1, name: "Pixel Painter", desc: "基于 Canvas 的在线像素画编辑器，支持多图层、自定义调色板、GIF/PNG 导出、历史撤销。", icon: "画", status: "开发中", accent: "var(--cyan)", iconBg: "rgba(94,234,212,0.1)", statusBg: "rgba(94,234,212,0.1)", tags: ["Canvas","JS","像素"] },
    { id: 2, name: "CatViewer", desc: "可爱的猫咪图片浏览器，支持懒加载和无限滚动，集成 Cat API 获取随机猫咪照片。", icon: "喵", status: "已完成", accent: "var(--purple)", iconBg: "rgba(167,139,250,0.1)", statusBg: "rgba(167,139,250,0.1)", tags: ["API","CSS","动画"] },
    { id: 3, name: "Sakura CSS", desc: "纯 CSS 实现的樱花飘落效果库，零依赖、轻量级，支持自定义花瓣数量、速度和颜色。", icon: "樱", status: "已完成", accent: "var(--orange)", iconBg: "rgba(251,146,60,0.1)", statusBg: "rgba(251,146,60,0.1)", tags: ["CSS","动画"] },
    { id: 4, name: "Pixel Weather", desc: "像素风天气卡片组件，集成 Open-Meteo API，支持实时天气和七日预报展示。", icon: "云", status: "计划中", accent: "var(--yellow)", iconBg: "rgba(251,191,36,0.1)", statusBg: "rgba(251,191,36,0.1)", tags: ["API","React"] }
  ];

  function renderProjects() {
    var grid = document.getElementById("projGrid"); if (!grid) return;
    grid.innerHTML = PROJECTS.map(function(p) {
      return "<div class=\"proj-card\" style=\"--proj-accent:" + p.accent + ";--proj-glow:rgba(255,107,157,0.12);--proj-icon-bg:" + p.iconBg + ";--proj-status-bg:" + p.statusBg + ";\">" +
        "<div class=\"proj-card-icon\">" + p.icon + "</div>" +
        "<div class=\"proj-card-name\">" + p.name + "</div>" +
        "<div class=\"proj-card-desc\">" + p.desc + "</div>" +
        "<div class=\"proj-card-footer\">" +
          "<span class=\"proj-card-status\">" + p.status + "</span>" +
          "<div class=\"proj-card-tags\">" + p.tags.map(function(t){return "<span class=\"proj-card-tag\">"+t+"</span>";}).join("") + "</div>" +
        "</div></div>";
    }).join("");
  }

  /* ===== Typewriter Effect for About Page ===== */
  var twEl = document.getElementById("aboutTypewriter");
  if (twEl) {
    var phrases = ["🎨", "✨", "🐱", "💻", "🌸", "🎮"];
    var twIdx = 0;
    function typeNext() {
      twEl.style.opacity = "0";
      setTimeout(function() {
        twEl.textContent = phrases[twIdx];
        twEl.style.opacity = "1";
        twEl.style.transition = "opacity 0.3s ease";
        twIdx = (twIdx + 1) % phrases.length;
      }, 400);
    }
    setInterval(typeNext, 2500);
    typeNext();
  }

  /* ===== Init ===== */
  renderCalendar();
  renderAlbums();
  renderProjects();

  /* Mouse tracking for proj-card and about-bio-card */
  document.addEventListener("mousemove", function(e) {
    document.querySelectorAll(".proj-card, .about-bio-card").forEach(function(c) {
      var r = c.getBoundingClientRect();
      c.style.setProperty("--mc-x", ((e.clientX - r.left) / r.width) * 100 + "%");
      c.style.setProperty("--mc-y", ((e.clientY - r.top) / r.height) * 100 + "%");
    });
  });

  /* Global Escape key handler — closes modals, lightbox, returns from project details */
  document.addEventListener('keydown', function(e) {
    if (e.key !== 'Escape') return;
    if (typeof lightboxEl !== 'undefined' && lightboxEl) { closeLightbox(); return; }
    var viewer = document.getElementById('albumViewer');
    if (viewer && viewer.style.display === 'flex') { viewer.style.display = 'none'; renderAlbums(); return; }
    var modal = document.getElementById('entryModal');
    if (modal && modal.style.display === 'flex') { modal.style.display = 'none'; return; }
    /* If on a project detail page, go back to projects */
    var activeDetail = document.querySelector('.section-page.active[id^="page-project-detail-"]');
    if (activeDetail) { navigateTo('projects'); return; }
  });

  /* ===== Pixel Painter Canvas Demo ===== */
  var painterInited = false;
  function initPixelPainter() {
    if (painterInited) return;
    var canvas = document.getElementById('painterCanvas');
    if (!canvas) return;
    var container = document.getElementById('painterDemo');
    if (!container) return;
    painterInited = true;
    canvas.width = container.clientWidth || 600;
    canvas.height = container.clientHeight || 200;
    var ctx = canvas.getContext('2d');
    var pixelSize = 12;
    var painterColor = '#ff6b9d';
    var painterDrawing = false;

    function drawGrid() {
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      for (var x = 0; x < canvas.width; x += pixelSize) {
        for (var y = 0; y < canvas.height; y += pixelSize) {
          ctx.fillStyle = (Math.floor(x/pixelSize) + Math.floor(y/pixelSize)) % 2 === 0 ? 'rgba(255,255,255,0.02)' : 'rgba(255,255,255,0.04)';
          ctx.fillRect(x, y, pixelSize, pixelSize);
        }
      }
      ctx.fillStyle = 'rgba(255,255,255,0.2)';
      ctx.font = '14px "Pixelify Sans"';
      ctx.textAlign = 'center';
      ctx.fillText('在此涂鸦!', canvas.width/2, canvas.height/2);
    }
    drawGrid();

    function drawPixel(e) {
      var rect = canvas.getBoundingClientRect();
      var scaleX = canvas.width / rect.width;
      var scaleY = canvas.height / rect.height;
      var x = Math.floor((e.clientX - rect.left) * scaleX / pixelSize);
      var y = Math.floor((e.clientY - rect.top) * scaleY / pixelSize);
      ctx.fillStyle = painterColor;
      ctx.fillRect(x * pixelSize, y * pixelSize, pixelSize, pixelSize);
    }

    canvas.addEventListener('mousedown', function(e) { painterDrawing = true; drawPixel(e); });
    canvas.addEventListener('mousemove', function(e) { if (painterDrawing) drawPixel(e); });
    canvas.addEventListener('mouseup', function() { painterDrawing = false; });
    canvas.addEventListener('mouseleave', function() { painterDrawing = false; });

    var palette = document.getElementById('painterPalette');
    if (palette && !palette.hasChildNodes()) {
      var colors = ['#ff6b9d','#5eead4','#fbbf24','#a78bfa','#fb923c','#fff','#94a3b8','#1e293b','#ef4444','#22c55e','#3b82f6','#f97316'];
      palette.innerHTML = colors.map(function(c) { return '<div class="painter-swatch'+(c===painterColor?' active':'')+'" style="background:'+c+'" data-color="'+c+'"></div>'; }).join('');
      palette.addEventListener('click', function(e) {
        var sw = e.target.closest('.painter-swatch');
        if (!sw) return;
        painterColor = sw.dataset.color;
        palette.querySelectorAll('.painter-swatch').forEach(function(s){ s.classList.remove('active'); });
        sw.classList.add('active');
      });
    }

    var toolbar = document.querySelector('.painter-toolbar-row');
    if (toolbar) {
      toolbar.addEventListener('click', function(e) {
        var btn = e.target.closest('.painter-tool-btn');
        if (!btn) return;
        var tool = btn.dataset.tool;
        toolbar.querySelectorAll('.painter-tool-btn').forEach(function(b){ b.classList.remove('active'); });
        btn.classList.add('active');
        if (tool === 'clear') { ctx.clearRect(0, 0, canvas.width, canvas.height); drawGrid(); }
        if (tool === 'fill') { ctx.fillStyle = painterColor; ctx.fillRect(0, 0, canvas.width, canvas.height); }
        if (tool === 'eraser') painterColor = '#080414';
      });
    }
  }

  /* ===== Sakura Petals Animation ===== */
  var sakuraInited = false;
  function initSakuraPetals() {
    if (sakuraInited) return;
    var container = document.getElementById('sakuraPetals');
    if (!container) return;
    sakuraInited = true;
    for (var i = 0; i < 20; i++) {
      var petal = document.createElement('div');
      petal.className = 'sakura-petal';
      petal.style.left = Math.random() * 100 + '%';
      petal.style.setProperty('--sx', (Math.random() - 0.5) * 120 + 'px');
      petal.style.setProperty('--sr', Math.random() * 720 + 'deg');
      petal.style.animationDuration = (6 + Math.random() * 10) + 's';
      petal.style.animationDelay = Math.random() * 8 + 's';
      petal.style.width = (10 + Math.random() * 12) + 'px';
      petal.style.height = (10 + Math.random() * 12) + 'px';
      container.appendChild(petal);
    }
  }

  /* ===== Cat Showcase Animation ===== */
  var catInited = false;
  function initCatShowcase() {
    if (catInited) return;
    var showcase = document.getElementById('catShowcase');
    if (!showcase) return;
    catInited = true;
    showcase.querySelectorAll('.cat-card').forEach(function(card, idx) {
      card.addEventListener('mouseenter', function() {
        var icon = card.querySelector('.cat-card-icon');
        if (icon) {
          icon.style.transform = 'scale(1.3) rotate(' + (idx % 2 === 0 ? '15deg' : '-15deg') + ')';
          icon.style.transition = 'transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1)';
        }
      });
      card.addEventListener('mouseleave', function() {
        var icon = card.querySelector('.cat-card-icon');
        if (icon) { icon.style.transform = ''; }
      });
    });
  }

  /* ===== Editor textarea auto-resize ===== */
  var ta = document.getElementById('mdEditor');
  if (ta) {
    ta.addEventListener('input', function() {
      this.style.height = 'auto';
      this.style.height = Math.max(this.scrollHeight, 250) + 'px';
    });
  }
</script>
