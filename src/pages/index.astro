  // 2. 提交逻辑 (QQ 头像识别版)
  window.toggleReplyBox = function(id) {
    var b = document.getElementById('box-' + id);
    if(b) b.style.display = b.style.display === 'none' ? 'flex' : 'none';
  };

  window.submitComment = async function(id, btnElement) {
    var nameInput = document.getElementById('name-' + id);
    var emailInput = document.getElementById('email-' + id);
    var contentInput = document.getElementById('text-' + id);
    
    var btn = btnElement || window.event?.target;
    if (!emailInput || !contentInput) return;

    var name = nameInput ? nameInput.value.trim() : '';
    var email = emailInput.value.trim();
    var content = contentInput.value.trim();

    if (!email || !content) { alert('邮箱和回复内容不能为空！'); return; }
    if (!email.includes('@')) { alert('请填写正确的邮箱格式！'); return; }

    if (btn) { btn.disabled = true; btn.innerText = '发送中...'; }

    try {
      var avatar_url = '';
      
      // 🌟 核心魔法：正则匹配 QQ 邮箱并调用腾讯官方头像 API
      var qqMatch = email.match(/^([1-9][0-9]{4,10})@qq\.com$/i);
      if (qqMatch) {
        var qqNum = qqMatch[1];
        avatar_url = 'https://q1.qlogo.cn/g?b=qq&nk=' + qqNum + '&s=100';
        if (!name) name = 'QQ网友'; // 没填昵称时，默认给个称呼
      } else {
        // 非 QQ 邮箱，使用 Cravatar
        var hash = typeof md5 === 'function' ? md5(email.toLowerCase()) : Date.now().toString();
        avatar_url = 'https://cravatar.cn/avatar/' + hash + '?d=identicon';
        if (!name) name = email.split('@')[0];
      }

      const response = await fetch('/api/comment', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        // 把 name 传给后端
        body: JSON.stringify({ diary_id: id, name: name, email: email, content: content, avatar_url: avatar_url })
      });

      const contentType = response.headers.get("content-type");
      if (contentType && contentType.includes("application/json")) {
        const result = await response.json();
        if (result.success) {
          if (nameInput) nameInput.value = '';
          if (emailInput) emailInput.value = '';
          if (contentInput) contentInput.value = '';
          fetchAndRenderDiaries(); // 成功后刷新
        } else {
          alert('回复失败: ' + (result.error || '未知错误'));
        }
      } else {
        console.error("后端异常日志:", await response.text());
        alert('后端连不上了，请检查数据库设置！');
      }
    } catch (e) {
      console.error(e);
      alert('网络波动，请重试！');
    } finally {
      if (btn) { btn.disabled = false; btn.innerText = '发送'; }
    }
  };
