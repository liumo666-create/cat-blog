    showcase.querySelectorAll('.cat-card').forEach(function(card, idx) {
      card.addEventListener('mouseenter', function() {
        var icon = card.querySelector('.cat-card-icon');
        if (icon) {
          icon.style.transform = 'scale(1.3) rotate(' + (idx % 2 === 0 ? '15deg' : '-15deg') + ')';
          icon.style.transition = 'transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1)';
        }
      });
      card.addEventListener('mouseleave', function() {
        var icon = card.querySelector('.cat-card-icon');
        if (icon) { icon.style.transform = ''; }
      });
    });
  }

  /* ===== Editor textarea auto-resize ===== */
  var ta = document.getElementById('mdEditor');
  if (ta) {
    ta.addEventListener('input', function() {
      this.style.height = 'auto';
      this.style.height = Math.max(this.scrollHeight, 250) + 'px';
    });
  }
