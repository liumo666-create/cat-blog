---
import Layout from "@layouts/Layout.astro";
import NavBar from "@components/NavBar.astro";
import HeroBanner from "@components/HeroBanner.astro";
import { getCollection } from "astro:content"; 

const allPosts = await getCollection("blog");
// 保证这里不报错
const sortedPosts = allPosts.sort((a: any, b: any) => b.data.date.valueOf() - a.data.date.valueOf());

// 🌟 终极修复：在顶部处理好 JSON 数据，不要在 HTML 里写类型推断！
const calendarPostsData = JSON.stringify(sortedPosts.map((p: any) => ({
  title: p.data.title,
  date: p.data.date.toISOString().slice(0, 10)
})));
---

<Layout>
  <div class="game-scene">  
    <div class="scroll-container" id="scrollContainer">
      <div class="web-wrapper">
        <NavBar />
        <HeroBanner />

     <!-- ===== HOME PAGE ===== -->
       <!-- ===== HOME PAGE ===== -->
        <div class="section-page active" id="page-home">
          <!-- 左侧：文章列表 -->
          <div class="main-col">
            <div class="section-title">知识库</div>
            <div class="post-list">
              {sortedPosts.map((post: any, index: number) => (
                <a href={`/post/${post.id}/`} class={`post-card-link post-item page-${Math.floor(index / 5) + 1}`} style={index >= 5 ? 'display: none;' : ''}>
                  <div class="post-card has-cover">
                    {post.data.cover && (
                      <div class="post-cover-wrap">
                        <img src={post.data.cover} alt={post.data.title} class="post-cover" />
                      </div>
                    )}
                    <div class="post-text-wrap">
                      <div class="post-date">{post.data.date.toISOString().slice(0,10)}</div>
                      <div class="post-title">{post.data.title}</div>
                      <div class="post-excerpt">{post.data.excerpt || "点击阅读全文..."}</div>
                      <div class="post-meta">
                        <span class="cat">{post.data.category}</span>
                        {post.data.tags.map((tag: string) => <span class="tag">{tag}</span>)}
                      </div>
                    </div>
                  </div>
                </a>
              ))}
            </div>
            
            {sortedPosts.length > 5 && (
              <div class="pagination-controls">
                <button class="glass-btn" id="prevPage" disabled style="opacity: 0.4;">上一页</button>
                <span class="page-indicator" id="pageIndicator">1 / {Math.ceil(sortedPosts.length / 5)}</span>
                <button class="glass-btn" id="nextPage" data-max={Math.ceil(sortedPosts.length / 5)}>下一页</button>
              </div>
            )}
          </div>

          <!-- 🌟 右侧：完美修复排版的侧边栏 🌟 -->
          <div class="side-col">
            
            <!-- 1. 紧凑版天气卡片 -->
            <div class="glass-card widget-card ultra-weather-card">
              <div class="uw-top-bar">
                <div class="uw-date" id="widgetDate">加载中...</div>
                <div class="uw-city-pill">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
                  荆州
                </div>
              </div>
              <div class="uw-clock" id="widgetClock">--:--:--</div>
              <div class="uw-bottom-bar">
                <div class="uw-main-anim" id="weatherAnim">
                  <div class="uw-loading-ring"></div>
                </div>
                <div class="uw-temp-wrap">
                  <div class="uw-temp" id="weatherTemp">--°</div>
                  <div class="uw-desc" id="weatherDesc">探测中</div>
                </div>
              </div>
            </div>

            <!-- 2. 聚合热力日历看板 -->
            <div class="glass-card calendar-widget" style="margin-bottom:12px;">
              <!-- 使用顶部生成好的纯净字符串，杜绝报错 -->
              <div id="astroPostsData" data-posts={calendarPostsData} style="display:none;"></div>
              
              <div class="calendar-header">
                <button class="calendar-btn" id="calPrev"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14"><path d="m15 18-6-6 6-6"/></svg></button>
                <span class="month-label" id="calMonthLabel"></span>
                <button class="calendar-btn" id="calNext"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14"><path d="m9 18 6-6-6-6"/></svg></button>
                <button class="calendar-btn" id="calAddNote" title="手动添加记录" style="margin-left:auto; border-color:transparent; color:var(--cyan);">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                </button>
              </div>
              
              <div class="calendar-grid" id="calGrid"></div>
              <div class="cal-heatmap-container" id="calHeatmap"></div>
              <div class="cal-activity-wrap">
                <div class="cal-activity-list" id="calActivityList"></div>
              </div>
            </div>

            <!-- 3. 原有的统计与标签代码 -->
            <div class="stats-grid">
              <div class="stat-item"><div class="stat-number" id="statPosts">0</div><div class="stat-label">文章</div></div>
              <div class="stat-item"><div class="stat-number" id="statPhotos">0</div><div class="stat-label">相册</div></div>
            </div>
            <div class="announce-box">
              <div class="ann-text">欢迎来到我的像素世界！这里记录了我的代码、设计与生活点滴。</div>
            </div>
            <div class="section-title" style="margin-top:16px;">分类</div>
            <div class="cat-list">
              <div class="cat-item"><span>设计</span><span class="count">3</span></div>
              <div class="cat-item"><span>开发</span><span class="count">5</span></div>
              <div class="cat-item"><span>像素画</span><span class="count">2</span></div>
              <div class="cat-item"><span>生活</span><span class="count">4</span></div>
            </div>
            <div class="section-title" style="margin-top:12px;">标签</div>
            <div class="tag-cloud">
              <span class="tag-chip">像素</span>
              <span class="tag-chip">博客</span>
              <span class="tag-chip">Canvas</span>
              <span class="tag-chip">JavaScript</span>
              <span class="tag-chip">设计</span>
              <span class="tag-chip">CSS</span>
              <span class="tag-chip">动画</span>
            </div>
          </div>
        </div>

<style is:global>

  /* 🌟 修复日间模式评论区文字和输入框看不清的问题 */
.game-scene.day-mode .comment-text { color: #475569 !important; }
.game-scene.day-mode .diary-reply-btn { color: #0d9488 !important; font-weight: 600; }
.game-scene.day-mode .reply-input, 
.game-scene.day-mode .reply-textarea { 
  background: rgba(255,255,255,0.8) !important; 
  color: #1e293b !important; 
  border: 1px solid rgba(0,0,0,0.2) !important; 
}
.game-scene.day-mode .reply-input::placeholder, 
.game-scene.day-mode .reply-textarea::placeholder { 
  color: #94a3b8 !important; 
}

  /* =================================================================== */
/* 🌟 高颜值回复框与评论区样式 */
/* =================================================================== */
.diary-comments-list { margin-top: 16px; padding-top: 12px; border-top: 1px dashed rgba(255,255,255,0.1); display: flex; flex-direction: column; gap: 12px; }
.diary-comment-item { display: flex; gap: 10px; font-size: 13px; align-items: flex-start; animation: fadeIn 0.4s ease forwards; }
.comment-avatar { width: 32px; height: 32px; border-radius: 8px; object-fit: cover; border: 1px solid rgba(255,255,255,0.1); box-shadow: 0 2px 6px rgba(0,0,0,0.2); }
.comment-content-box { flex: 1; background: rgba(255,255,255,0.04); padding: 10px 14px; border-radius: 4px 12px 12px 12px; line-height: 1.6; border: 1px solid rgba(255,255,255,0.02); }
.comment-email { font-weight: 800; color: var(--pink); margin-right: 8px; font-family: 'JetBrains Mono', monospace; }
.comment-text { color: #e2e8f0; }

.diary-reply-box { margin-top: 12px; display: flex; flex-direction: column; gap: 10px; background: rgba(0,0,0,0.25); padding: 16px; border-radius: 12px; border: 1px solid rgba(255,255,255,0.05); animation: slideDown 0.3s cubic-bezier(0.16, 1, 0.3, 1); overflow: hidden; }
@keyframes slideDown { from { opacity: 0; transform: translateY(-10px); } to { opacity: 1; transform: translateY(0); } }
.reply-input, .reply-textarea { width: 100%; background: rgba(0,0,0,0.4); border: 1px solid rgba(255,255,255,0.1); color: #fff; padding: 12px; border-radius: 8px; font-size: 13px; outline: none; transition: all 0.3s ease; box-sizing: border-box; font-family: inherit; }
.reply-input:focus, .reply-textarea:focus { border-color: var(--cyan); box-shadow: 0 0 0 2px rgba(94, 234, 212, 0.15); background: rgba(0,0,0,0.6); }
.reply-textarea { resize: vertical; min-height: 60px; }
.reply-submit-btn { align-self: flex-end; background: rgba(255, 107, 157, 0.1); color: var(--pink); border: 1px solid var(--pink); padding: 8px 20px; border-radius: 8px; cursor: pointer; font-size: 13px; font-weight: bold; transition: all 0.3s ease; }
.reply-submit-btn:hover { background: var(--pink); color: #fff; box-shadow: 0 4px 12px rgba(255, 107, 157, 0.3); transform: translateY(-1px); }
/* =================================================================== */
/* 🌟 像素朋友圈/碎片日记 专属样式 */
/* =================================================================== */
.diary-container { max-width: 680px; margin: 0 auto; width: 100%; padding-bottom: 40px; }

/* 顶部封面图 */
.diary-header-cover {
  height: 260px; border-radius: 16px; position: relative; margin-bottom: 60px;
  background: linear-gradient(to bottom, rgba(0,0,0,0.1), rgba(0,0,0,0.8)), url('https://images.unsplash.com/photo-1550684848-fac1c5b4e853?q=80&w=1000&auto=format&fit=crop') center/cover;
  box-shadow: 0 10px 30px rgba(0,0,0,0.3); border: 1px solid rgba(255,255,255,0.1);
}
.diary-header-avatar { position: absolute; right: 24px; bottom: -30px; display: flex; align-items: flex-end; gap: 16px; }
.diary-header-avatar span { color: #fff; font-weight: 700; font-size: 22px; text-shadow: 0 2px 8px rgba(0,0,0,0.8); margin-bottom: 40px; font-family: var(--font-pixel); letter-spacing: 2px;}
.diary-header-avatar img { width: 84px; height: 84px; border-radius: 16px; border: 4px solid var(--bg); box-shadow: 0 6px 16px rgba(0,0,0,0.3); background: var(--bg); object-fit: cover; }
.game-scene.day-mode .diary-header-avatar img { border-color: #f8fafc; }

/* 发布编辑器 */
.diary-composer { padding: 16px 20px; margin-bottom: 30px; border-radius: 16px; transition: all 0.3s; }
.diary-composer:focus-within { border-color: var(--cyan); box-shadow: 0 0 20px rgba(94, 234, 212, 0.15); }
.diary-composer textarea { width: 100%; min-height: 80px; background: transparent; border: none; color: var(--text); font-family: var(--font-body); font-size: 15px; resize: none; outline: none; margin-bottom: 12px; line-height: 1.6; }
.diary-composer textarea::placeholder { color: var(--muted); }

/* 图片预览区 */
.diary-image-previews { display: flex; flex-wrap: wrap; gap: 10px; margin-bottom: 16px; }
.diary-preview-item { position: relative; width: 80px; height: 80px; border-radius: 8px; overflow: hidden; box-shadow: 0 4px 10px rgba(0,0,0,0.2); }
.diary-preview-item img { width: 100%; height: 100%; object-fit: cover; }
.diary-preview-del { position: absolute; top: 4px; right: 4px; width: 22px; height: 22px; background: rgba(0,0,0,0.6); color: #fff; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 14px; cursor: pointer; transition: all 0.2s; backdrop-filter: blur(4px); }
.diary-preview-del:hover { background: #f87171; transform: scale(1.1); }

/* 发布工具栏 */
.diary-toolbar { display: flex; justify-content: space-between; align-items: center; border-top: 1px dashed var(--border-hi); padding-top: 14px; }
.diary-tool-btn { background: transparent; border: none; color: var(--text-secondary); cursor: pointer; display: flex; align-items: center; justify-content: center; width: 38px; height: 38px; border-radius: 50%; transition: all 0.2s; background: rgba(255,255,255,0.03); }
.diary-tool-btn:hover { background: rgba(94, 234, 212, 0.15); color: var(--cyan); transform: translateY(-2px); }

/* 信息流单条动态 */
.diary-post { display: flex; gap: 16px; padding: 24px 0; border-bottom: 1px solid rgba(255,255,255,0.05); animation: fadeInUp 0.5s ease; }
.game-scene.day-mode .diary-post { border-bottom-color: rgba(0,0,0,0.05); }
.diary-avatar { flex-shrink: 0; }
.diary-avatar img { width: 46px; height: 46px; border-radius: 10px; box-shadow: 0 4px 10px rgba(0,0,0,0.1); }
.diary-body { flex: 1; min-width: 0; }
.diary-author { font-weight: 700; color: var(--cyan); font-size: 16px; margin-bottom: 6px; display: flex; align-items: center; gap: 8px; font-family: var(--font-body); }
.diary-badge { font-size: 10px; padding: 2px 6px; border-radius: 4px; background: rgba(255,107,157,0.1); color: var(--pink); font-weight: normal; border: 1px solid rgba(255,107,157,0.3); }
.diary-content { font-size: 15px; color: var(--text); line-height: 1.7; word-wrap: break-word; }
.diary-content p { margin-bottom: 8px; }
.diary-content p:last-child { margin-bottom: 0; }

/* 微信同款九宫格相册排版 */
.diary-img-grid { display: grid; gap: 6px; margin-top: 12px; }
.diary-img-grid.grid-1 { grid-template-columns: 1fr; max-width: 240px; }
.diary-img-grid.grid-2 { grid-template-columns: repeat(2, 1fr); max-width: 260px; }
.diary-img-grid.grid-multi { grid-template-columns: repeat(3, 1fr); max-width: 340px; }
.diary-img-grid img { width: 100%; aspect-ratio: 1; object-fit: cover; border-radius: 8px; cursor: zoom-in; transition: transform 0.2s, filter 0.2s; box-shadow: 0 2px 8px rgba(0,0,0,0.2); }
.diary-img-grid img:hover { filter: brightness(1.15); }
.diary-img-grid.grid-1 img { aspect-ratio: auto; max-height: 300px; }

.diary-footer { display: flex; justify-content: space-between; align-items: center; margin-top: 14px; font-size: 13px; font-family: 'JetBrains Mono', monospace; }
.diary-time { color: var(--muted); }
.diary-delete { color: #f87171; cursor: pointer; opacity: 0; transition: opacity 0.2s; font-family: var(--font-body); font-size: 13px; font-weight: 500; }
.diary-post:hover .diary-delete { opacity: 1; }

.diary-empty { text-align: center; padding: 60px 0; color: var(--muted); font-size: 15px; background: rgba(255,255,255,0.02); border-radius: 12px; border: 1px dashed var(--border-hi); }
.diary-lightbox .lightbox-counter { position: absolute; top: 20px; left: 50%; transform: translateX(-50%); color: #fff; font-size: 16px; font-family: 'JetBrains Mono', monospace; letter-spacing: 2px; text-shadow: 0 2px 4px rgba(0,0,0,0.8); }



/* =================================================================== */
/* 🌟 修复点 2：将天气和日历的 CSS 安全打包，绝不干扰 JS 引擎 */
/* =================================================================== */

/* ----- 天气卡片样式 ----- */
.ultra-weather-card { display: flex; flex-direction: column; padding: 16px 18px; margin-bottom: 12px; position: relative; background: transparent; }
.uw-top-bar { display: flex; justify-content: space-between; align-items: center; width: 100%; margin-bottom: 8px; }
.uw-date { font-family: var(--font-body); font-size: 12px; color: var(--muted); letter-spacing: 1px; font-weight: 500; }
.game-scene.day-mode .uw-date { color: #666; }
.uw-city-pill { display: inline-flex; align-items: center; gap: 4px; padding: 3px 10px; background: rgba(255, 107, 157, 0.08); border: 1px solid rgba(255, 107, 157, 0.25); border-radius: 20px; color: var(--pink); font-size: 12px; font-weight: 600; box-shadow: 0 2px 8px rgba(255, 107, 157, 0.1); animation: pill-breathe 3.5s ease-in-out infinite; }
.uw-city-pill svg { width: 12px; height: 12px; }
.game-scene.day-mode .uw-city-pill { background: rgba(217, 70, 111, 0.08); border-color: rgba(217, 70, 111, 0.25); color: #d9466f; }
@keyframes pill-breathe { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-2px); box-shadow: 0 4px 12px rgba(255,107,157,0.2); } }
.uw-clock { font-family: var(--font-pixel); font-size: 38px; font-weight: 700; color: var(--cyan); letter-spacing: 2px; line-height: 1; text-align: center; text-shadow: 0 4px 12px rgba(94, 234, 212, 0.3); margin-bottom: 12px; }
.game-scene.day-mode .uw-clock { color: #0d9488; text-shadow: 0 2px 8px rgba(13,148,136,0.15); }
.uw-bottom-bar { display: flex; justify-content: center; align-items: center; gap: 16px; width: 100%; }
.uw-temp-wrap { display: flex; flex-direction: column; align-items: flex-start; gap: 2px; }
.uw-temp { font-family: var(--font-pixel); font-size: 36px; font-weight: 700; color: var(--yellow); line-height: 1; text-shadow: 0 4px 16px rgba(251, 191, 36, 0.3); }
.game-scene.day-mode .uw-temp { color: #d97706; text-shadow: none; }
.uw-desc { font-family: var(--font-body); font-size: 14px; color: var(--text); font-weight: 600; letter-spacing: 1px; }
.uw-main-anim { width: 50px; height: 50px; display: flex; justify-content: center; align-items: center; position: relative; }
.wi-sun-wrapper { position: relative; width: 50px; height: 50px; display: flex; justify-content: center; align-items: center; }
.wi-sun { width: 28px; height: 28px; background: #fbbf24; border-radius: 50%; box-shadow: 0 0 20px rgba(251,191,36,0.8); position: relative; z-index: 2; animation: sun-pulse 3s infinite alternate ease-in-out; }
.wi-sun-aura { position: absolute; width: 46px; height: 46px; border: 2px dashed rgba(251,191,36,0.5); border-radius: 50%; animation: sun-spin 12s linear infinite; z-index: 1; }
@keyframes sun-spin { 100% { transform: rotate(360deg); } }
@keyframes sun-pulse { 0% { transform: scale(0.95); } 100% { transform: scale(1.05); box-shadow: 0 0 30px rgba(251,191,36,1); } }
.wi-moon-wrapper { position: relative; width: 44px; height: 44px; }
.wi-moon { width: 36px; height: 36px; border-radius: 50%; box-shadow: inset -10px -5px 0 0 #fde047; filter: drop-shadow(0 0 10px rgba(253,224,71,0.5)); animation: moon-float 4s ease-in-out infinite; position: absolute; top: 4px; left: 4px; }
.wi-star { position: absolute; color: #fff; font-size: 12px; animation: star-twinkle 2s infinite alternate; }
.wi-star.s1 { top: -2px; left: -6px; animation-delay: 0s; }
.wi-star.s2 { top: 18px; left: -16px; font-size: 8px; animation-delay: 1s; }
@keyframes moon-float { 0%, 100% { transform: translateY(0) rotate(-10deg); } 50% { transform: translateY(-4px) rotate(5deg); } }
@keyframes star-twinkle { 0% { opacity: 0.2; transform: scale(0.6); } 100% { opacity: 1; transform: scale(1.2); text-shadow: 0 0 8px #fff; } }
.game-scene.day-mode .wi-moon { box-shadow: inset -10px -5px 0 0 #fbbf24; }
.game-scene.day-mode .wi-star { color: #fbbf24; }
.wi-cloud-group { position: relative; width: 56px; height: 40px; }
.wi-cloud { width: 46px; height: 16px; background: #e2e8f0; border-radius: 20px; position: absolute; bottom: 4px; left: 0; z-index: 2; animation: cloud-float 4s ease-in-out infinite; box-shadow: 0 6px 12px rgba(0,0,0,0.15); }
.wi-cloud::before { content: ''; position: absolute; width: 22px; height: 22px; background: inherit; border-radius: 50%; top: -12px; left: 6px; }
.wi-cloud::after { content: ''; position: absolute; width: 28px; height: 28px; background: inherit; border-radius: 50%; top: -16px; right: 4px; }
.wi-cloud-back { width: 36px; height: 12px; background: #94a3b8; border-radius: 20px; position: absolute; bottom: 16px; right: 0; opacity: 0.7; z-index: 1; animation: cloud-float 5s ease-in-out infinite alternate; }
.wi-cloud-back::before { content: ''; position: absolute; width: 18px; height: 18px; background: inherit; border-radius: 50%; top: -10px; left: 4px; }
@keyframes cloud-float { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-4px); } }
.game-scene.day-mode .wi-cloud { background: #fff; box-shadow: 0 4px 10px rgba(0,0,0,0.05); }
.wi-rain-group { position: relative; width: 56px; height: 50px; }
.wi-rain-group .wi-cloud { background: #64748b; bottom: 20px; box-shadow: 0 6px 12px rgba(0,0,0,0.3); }
.wi-rain-group .wi-cloud::before, .wi-rain-group .wi-cloud::after { background: inherit; }
.wi-rain-drops { position: absolute; bottom: 0; left: 8px; display: flex; gap: 10px; z-index: 1; }
.wi-drop { width: 2px; height: 10px; background: #38bdf8; border-radius: 2px; animation: rain-fall 0.7s linear infinite; }
@keyframes rain-fall { 0% { transform: translateY(0) rotate(15deg); opacity: 1; } 100% { transform: translateY(20px) rotate(15deg); opacity: 0; } }
.wi-snow-group { position: relative; width: 56px; height: 50px; }
.wi-snow-group .wi-cloud { background: #94a3b8; bottom: 20px; box-shadow: 0 6px 12px rgba(0,0,0,0.2); }
.wi-snow-group .wi-cloud::before, .wi-snow-group .wi-cloud::after { background: inherit; }
.wi-snowflakes { position: absolute; bottom: 0; left: 8px; display: flex; gap: 12px; z-index: 1; }
.wi-flake { width: 5px; height: 5px; background: #fff; border-radius: 50%; animation: snow-fall 1.5s ease-in infinite; box-shadow: 0 0 3px rgba(255,255,255,0.8); }
@keyframes snow-fall { 0% { transform: translateY(0) rotate(10deg); opacity: 1; } 100% { transform: translateY(20px) rotate(-10deg); opacity: 0; } }
.uw-loading-ring { width: 24px; height: 24px; border: 2px solid rgba(255,255,255,0.1); border-top-color: var(--cyan); border-radius: 50%; animation: sun-spin 1s linear infinite; }
.game-scene.day-mode .uw-loading-ring { border-color: rgba(0,0,0,0.1); border-top-color: #0d9488; }

/* ----- 日历看板样式 ----- */
/* ----- 🌟 高级极客版日历看板样式 ----- */
.calendar-widget { padding: 20px 18px; }
.calendar-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 16px; }
.month-label { font-family: var(--font-body); font-weight: 800; font-size: 18px; color: var(--text); letter-spacing: 1px; }
.calendar-btn { background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.05); border-radius: 8px; width: 32px; height: 32px; display: flex; align-items: center; justify-content: center; cursor: pointer; color: var(--text-secondary); transition: all 0.2s; }
.calendar-btn:hover { background: rgba(255,255,255,0.1); color: var(--text); }
.calendar-btn.add-btn { background: transparent; border: none; }
.calendar-btn.add-btn:hover { transform: scale(1.15) rotate(90deg); }

.calendar-grid { display: grid; grid-template-columns: repeat(7, 1fr); gap: 6px; text-align: center; margin-bottom: 20px; }
.day-header { font-size: 12px; color: var(--muted); margin-bottom: 8px; font-weight: 500; }
.day-cell { 
  position: relative; height: 34px; display: flex; align-items: center; justify-content: center; 
  font-size: 15px; font-family: 'JetBrains Mono', var(--font-body); font-weight: 700; color: var(--text); 
  border-radius: 8px; cursor: pointer; transition: all 0.2s; user-select: none;
}
.day-cell:hover { background: rgba(255,255,255,0.08); }
.day-cell.other-month { opacity: 0.25; font-weight: 500; }
.day-cell.selected { border: 1px solid rgba(94,234,212,0.8); box-shadow: 0 0 12px rgba(94,234,212,0.15); background: rgba(94,234,212,0.05); }

/* 🌟 图一同款：右上角数字角标与底部蓝点 */
.day-badge { position: absolute; top: 0px; right: 2px; font-size: 10px; color: var(--cyan); font-weight: 800; font-family: 'JetBrains Mono', monospace; text-shadow: 0 0 4px rgba(94,234,212,0.5); }
.day-dot { position: absolute; bottom: 4px; left: 50%; transform: translateX(-50%); width: 4px; height: 4px; background: var(--cyan); border-radius: 50%; box-shadow: 0 0 6px var(--cyan); }

/* 🌟 年度 12x4 月/周 热力图与悬浮气泡 */
.cal-heatmap-container { 
  display: flex; flex-direction: column; gap: 6px; 
  margin-bottom: 16px; padding-bottom: 16px; border-bottom: 1px solid rgba(255,255,255,0.05); 
}
.game-scene.day-mode .cal-heatmap-container { border-bottom-color: rgba(0,0,0,0.1); }

/* 顶部的月份数字 1-12 */
.hm-months { 
  display: grid; grid-template-columns: repeat(12, 1fr); gap: 4px; 
  text-align: center; font-size: 11px; font-weight: 700; color: var(--muted); margin-bottom: 2px; font-family: 'JetBrains Mono', monospace;
}

/* 12x4 的格子网格 */
.hm-grid { display: grid; grid-template-columns: repeat(12, 1fr); gap: 4px; }
.hm-cell { 
  position: relative; width: 100%; aspect-ratio: 1; border-radius: 4px; 
  background: rgba(255,255,255,0.05); /* 夜间模式空闲格子 */
  transition: all 0.2s ease; cursor: pointer; border: 1px solid transparent;
}
/* 🌟 修复：日间模式的空闲格子清晰可见 */
.game-scene.day-mode .hm-cell { background: rgba(0,0,0,0.06); }

.hm-cell:hover { transform: scale(1.15); border-radius: 2px; z-index: 10; border-color: rgba(94,234,212,0.8); }
.hm-cell.selected { border-color: var(--cyan); box-shadow: 0 0 10px rgba(94,234,212,0.3); transform: scale(1.1); z-index: 5; }

/* 热力等级颜色 */
.hm-cell.lvl-1 { background: rgba(94,234,212,0.3); }
.hm-cell.lvl-2 { background: rgba(94,234,212,0.6); }
.hm-cell.lvl-3 { background: rgba(94,234,212,1); box-shadow: 0 0 8px rgba(94,234,212,0.6); }
/* 🌟 修复：日间模式的热力等级颜色 */
.game-scene.day-mode .hm-cell.lvl-1 { background: rgba(13,148,136,0.25); }
.game-scene.day-mode .hm-cell.lvl-2 { background: rgba(13,148,136,0.55); }
.game-scene.day-mode .hm-cell.lvl-3 { background: rgba(13,148,136,0.9); }

/* 高级悬浮气泡 */
.hm-cell::before {
  content: attr(data-tooltip); position: absolute; bottom: 130%; left: 50%; transform: translateX(-50%) scale(0.8);
  background: #1a1a1a; color: #fff; padding: 6px 12px; border-radius: 6px; font-size: 12px; font-family: var(--font-body);
  white-space: nowrap; opacity: 0; visibility: hidden; transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
  pointer-events: none; z-index: 100; border: 1px solid rgba(255,255,255,0.1); box-shadow: 0 10px 20px rgba(0,0,0,0.3);
}
.hm-cell::after {
  content: ''; position: absolute; bottom: 100%; left: 50%; transform: translateX(-50%); border-width: 5px; border-style: solid;
  border-color: #1a1a1a transparent transparent transparent; opacity: 0; visibility: hidden; transition: all 0.2s; z-index: 100;
}
.hm-cell:hover::before { opacity: 1; visibility: visible; transform: translateX(-50%) scale(1); }
.hm-cell:hover::after { opacity: 1; visibility: visible; }
/* 🌟 极简透明活动列表（图一同款） */
.cal-activity-wrap { max-height: 180px; overflow-y: auto; padding-right: 4px; }
.cal-activity-wrap::-webkit-scrollbar { width: 4px; }
.cal-activity-wrap::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.1); border-radius: 4px; }
.act-item { 
  display: flex; align-items: center; justify-content: space-between; 
  padding: 12px 8px; border-bottom: 1px solid rgba(255,255,255,0.05); 
  background: transparent; margin-bottom: 0; transition: all 0.2s;
}
.act-item.clickable { cursor: pointer; }
.act-item.clickable:hover { background: rgba(255,255,255,0.04); border-radius: 6px; border-bottom-color: transparent; padding-left: 12px; }
.act-left { display: flex; align-items: center; gap: 12px; overflow: hidden; }
.act-icon { font-size: 14px; opacity: 0.8; filter: grayscale(0.5); }
.act-title { font-family: var(--font-body); font-size: 14px; color: var(--text); font-weight: 500; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 150px; }
.act-date { font-family: 'JetBrains Mono', monospace; font-size: 12px; color: var(--muted); flex-shrink: 0; }
.act-empty { text-align: center; color: var(--muted); font-size: 12px; padding: 24px 0; font-family: var(--font-body); }
