  var albumAddFileInput = document.getElementById('albumAddFileInput');
  if (albumAddFileInput) albumAddFileInput.addEventListener('change', function(e){
    var files = e.target.files;
    if (!files.length || currentViewingAlbum < 0) return;
    var albums = getAlbums(), album = albums[currentViewingAlbum];
    if (!album) return;
    if (!album.photos) album.photos = [];
    var loaded = 0;
    for (var i = 0; i < files.length; i++) {
      (function(file){
        var r = new FileReader();
        r.onload = function(ev) {
          album.photos.push(ev.target.result);
          loaded++;
          if (loaded === files.length) {
            saveAlbums(albums);
            openAlbumViewer(currentViewingAlbum);
            renderAlbums();
