  /* Album viewer controls */
  var btnAlbumClose = document.getElementById('btnAlbumClose');
  if (btnAlbumClose) btnAlbumClose.addEventListener('click', function(){
    var viewer = document.getElementById('albumViewer');
    if (viewer) viewer.style.display = 'none';
    renderAlbums();
  });
  var btnAddToAlbum = document.getElementById('btnAddToAlbum');
  if (btnAddToAlbum) btnAddToAlbum.addEventListener('click', function(){
    var fi = document.getElementById('albumAddFileInput');
