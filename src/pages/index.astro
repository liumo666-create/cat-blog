---
import Layout from "@layouts/Layout.astro";
import NavBar from "@components/NavBar.astro";
import HeroBanner from "@components/HeroBanner.astro";
// 🌟 核心修改 1：额外引入 type CollectionEntry
import { getCollection, type CollectionEntry } from "astro:content"; 

const allPosts = await getCollection("blog");
// 🌟 核心修改 2：明确指定 a 和 b 的类型为 CollectionEntry<"blog">
const sortedPosts = allPosts.sort((a: CollectionEntry<"blog">, b: CollectionEntry<"blog">) => b.data.date.valueOf() - a.data.date.valueOf());
---

<Layout>
  <div class="game-scene">  
    <div class="scroll-container" id="scrollContainer">
      <div class="web-wrapper">
        <NavBar />
        <HeroBanner />

     <!-- ===== HOME PAGE ===== -->
        <div class="section-page active" id="page-home">
          
          <!-- 👇👇👇 请把你原来的 <div class="main-col">...</div> 全部替换成下面这一整块 👇👇👇 -->
          <div class="main-col">
            <div class="section-title">知识库</div>
            
            <!-- 🌟 全新由 Astro 静态生成的带封面文章列表 -->
      
            <div class="post-list">
              <!-- 🌟 核心修改 3：标注 post 和 index 的类型 -->
              {sortedPosts.map((post: CollectionEntry<"blog">, index: number) => (
                <a href={`/post/${post.id}/`} class={`post-card-link post-item page-${Math.floor(index / 5) + 1}`} style={index >= 5 ? 'display: none;' : ''}>
                  <div class="post-card has-cover">
                    {/* 如果 md 文件配置了封面图，则显示精美左侧封面 */}
                    {post.data.cover && (
                      <div class="post-cover-wrap">
                        <img src={post.data.cover} alt={post.data.title} class="post-cover" />
                      </div>
                    )}
                    
                    <div class="post-text-wrap">
                      <div class="post-date">{post.data.date.toISOString().slice(0,10)}</div>
                      <div class="post-title">{post.data.title}</div>
                      <div class="post-excerpt">{post.data.excerpt || "点击阅读全文..."}</div>
                      <div class="post-meta">
                        <span class="cat">{post.data.category}</span>
                        <!-- 🌟 核心修改 4：标注 tag 的类型为 string -->
                        {post.data.tags.map((tag: string) => <span class="tag">{tag}</span>)}
                      </div>
                    </div>
                  </div>
                </a>
              ))}
            </div>
            
            <!-- 🌟 精美的底部翻页控件 -->
            {sortedPosts.length > 5 && (
              <div class="pagination-controls">
                <button class="glass-btn" id="prevPage" disabled style="opacity: 0.4;">上一页</button>
                <span class="page-indicator" id="pageIndicator">1 / {Math.ceil(sortedPosts.length / 5)}</span>
                <button class="glass-btn" id="nextPage" data-max={Math.ceil(sortedPosts.length / 5)}>下一页</button>
              </div>
            )}
          </div>
          <!-- 👆👆👆 替换到这里结束 👆👆👆 -->
          <div class="side-col">
<!-- 新代码：替换到 index.astro 中 -->
