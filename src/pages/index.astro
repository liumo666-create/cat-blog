  /* ===== Render Projects ===== */
  var PROJECTS = [
    { id: 0, name: "FYH Blog", desc: "像素风格个人博客，Astro + Svelte 构建，支持 Markdown 写作、相册管理、日历记事、日夜主题切换。", icon: "猫", status: "活跃开发中", accent: "var(--pink)", iconBg: "rgba(255,107,157,0.1)", statusBg: "rgba(255,107,157,0.1)", tags: ["Astro","Svelte","CSS"] },
    { id: 1, name: "Pixel Painter", desc: "基于 Canvas 的在线像素画编辑器，支持多图层、自定义调色板、GIF/PNG 导出、历史撤销。", icon: "画", status: "开发中", accent: "var(--cyan)", iconBg: "rgba(94,234,212,0.1)", statusBg: "rgba(94,234,212,0.1)", tags: ["Canvas","JS","像素"] },
    { id: 2, name: "CatViewer", desc: "可爱的猫咪图片浏览器，支持懒加载和无限滚动，集成 Cat API 获取随机猫咪照片。", icon: "喵", status: "已完成", accent: "var(--purple)", iconBg: "rgba(167,139,250,0.1)", statusBg: "rgba(167,139,250,0.1)", tags: ["API","CSS","动画"] },
    { id: 3, name: "Sakura CSS", desc: "纯 CSS 实现的樱花飘落效果库，零依赖、轻量级，支持自定义花瓣数量、速度和颜色。", icon: "樱", status: "已完成", accent: "var(--orange)", iconBg: "rgba(251,146,60,0.1)", statusBg: "rgba(251,146,60,0.1)", tags: ["CSS","动画"] },
    { id: 4, name: "Pixel Weather", desc: "像素风天气卡片组件，集成 Open-Meteo API，支持实时天气和七日预报展示。", icon: "云", status: "计划中", accent: "var(--yellow)", iconBg: "rgba(251,191,36,0.1)", statusBg: "rgba(251,191,36,0.1)", tags: ["API","React"] }
  ];

  function renderProjects() {
    var grid = document.getElementById("projGrid"); if (!grid) return;
