      return "<div class=\"proj-card\" style=\"--proj-accent:" + p.accent + ";--proj-glow:rgba(255,107,157,0.12);--proj-icon-bg:" + p.iconBg + ";--proj-status-bg:" + p.statusBg + ";\">" +
