    e.stopPropagation();
    var pi = parseInt(del.dataset.del), albums = getAlbums();
    if (currentViewingAlbum >= 0 && albums[currentViewingAlbum]) {
      albums[currentViewingAlbum].photos.splice(pi, 1);
      saveAlbums(albums);
      openAlbumViewer(currentViewingAlbum);
      renderAlbums();
    }
  });
  /* Lightbox on photo click */
  if (albumViewerImages) albumViewerImages.addEventListener('click', function(e){
    var photo = e.target.closest('.album-viewer-photo');
