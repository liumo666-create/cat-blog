  /* ===== Pixel Painter Canvas Demo ===== */
  var painterInited = false;
  function initPixelPainter() {
    if (painterInited) return;
    var canvas = document.getElementById('painterCanvas');
    if (!canvas) return;
    var container = document.getElementById('painterDemo');
    if (!container) return;
    painterInited = true;
    canvas.width = container.clientWidth || 600;
    canvas.height = container.clientHeight || 200;
    var ctx = canvas.getContext('2d');
    var pixelSize = 12;
    var painterColor = '#ff6b9d';
    var painterDrawing = false;

    function drawGrid() {
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      for (var x = 0; x < canvas.width; x += pixelSize) {
        for (var y = 0; y < canvas.height; y += pixelSize) {
          ctx.fillStyle = (Math.floor(x/pixelSize) + Math.floor(y/pixelSize)) % 2 === 0 ? 'rgba(255,255,255,0.02)' : 'rgba(255,255,255,0.04)';
          ctx.fillRect(x, y, pixelSize, pixelSize);
        }
      }
      ctx.fillStyle = 'rgba(255,255,255,0.2)';
      ctx.font = '14px "Pixelify Sans"';
      ctx.textAlign = 'center';
      ctx.fillText('在此涂鸦!', canvas.width/2, canvas.height/2);
    }
    drawGrid();

    function drawPixel(e) {
      var rect = canvas.getBoundingClientRect();
      var scaleX = canvas.width / rect.width;
      var scaleY = canvas.height / rect.height;
      var x = Math.floor((e.clientX - rect.left) * scaleX / pixelSize);
      var y = Math.floor((e.clientY - rect.top) * scaleY / pixelSize);
      ctx.fillStyle = painterColor;
      ctx.fillRect(x * pixelSize, y * pixelSize, pixelSize, pixelSize);
    }

    canvas.addEventListener('mousedown', function(e) { painterDrawing = true; drawPixel(e); });
    canvas.addEventListener('mousemove', function(e) { if (painterDrawing) drawPixel(e); });
    canvas.addEventListener('mouseup', function() { painterDrawing = false; });
    canvas.addEventListener('mouseleave', function() { painterDrawing = false; });

    var palette = document.getElementById('painterPalette');
    if (palette && !palette.hasChildNodes()) {
      var colors = ['#ff6b9d','#5eead4','#fbbf24','#a78bfa','#fb923c','#fff','#94a3b8','#1e293b','#ef4444','#22c55e','#3b82f6','#f97316'];
      palette.innerHTML = colors.map(function(c) { return '<div class="painter-swatch'+(c===painterColor?' active':'')+'" style="background:'+c+'" data-color="'+c+'"></div>'; }).join('');
      palette.addEventListener('click', function(e) {
        var sw = e.target.closest('.painter-swatch');
        if (!sw) return;
        painterColor = sw.dataset.color;
        palette.querySelectorAll('.painter-swatch').forEach(function(s){ s.classList.remove('active'); });
        sw.classList.add('active');
      });
    }

    var toolbar = document.querySelector('.painter-toolbar-row');
    if (toolbar) {
      toolbar.addEventListener('click', function(e) {
        var btn = e.target.closest('.painter-tool-btn');
        if (!btn) return;
        var tool = btn.dataset.tool;
        toolbar.querySelectorAll('.painter-tool-btn').forEach(function(b){ b.classList.remove('active'); });
        btn.classList.add('active');
        if (tool === 'clear') { ctx.clearRect(0, 0, canvas.width, canvas.height); drawGrid(); }
        if (tool === 'fill') { ctx.fillStyle = painterColor; ctx.fillRect(0, 0, canvas.width, canvas.height); }
        if (tool === 'eraser') painterColor = '#080414';
      });
    }
  }

  /* ===== Sakura Petals Animation ===== */
  var sakuraInited = false;
  function initSakuraPetals() {
    if (sakuraInited) return;
    var container = document.getElementById('sakuraPetals');
    if (!container) return;
    sakuraInited = true;
    for (var i = 0; i < 20; i++) {
      var petal = document.createElement('div');
      petal.className = 'sakura-petal';
      petal.style.left = Math.random() * 100 + '%';
      petal.style.setProperty('--sx', (Math.random() - 0.5) * 120 + 'px');
      petal.style.setProperty('--sr', Math.random() * 720 + 'deg');
      petal.style.animationDuration = (6 + Math.random() * 10) + 's';
      petal.style.animationDelay = Math.random() * 8 + 's';
      petal.style.width = (10 + Math.random() * 12) + 'px';
      petal.style.height = (10 + Math.random() * 12) + 'px';
      container.appendChild(petal);
    }
  }

  /* ===== Cat Showcase Animation ===== */
  var catInited = false;
  function initCatShowcase() {
    if (catInited) return;
